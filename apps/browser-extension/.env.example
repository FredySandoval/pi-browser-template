# Copy this file to .env, .env.local, .env.development, .env.production,
# .env.chrome, .env.firefox, .env.development.chrome, etc. as needed.
# development | production
NODE_ENV=development

# To generate WXT_CHROME_EXTENSION_KEY:
#
#   # From repo root, or anywhere safe
#   mkdir -p .keys
#   # 1. Generate private key
#   openssl genrsa -out .keys/chrome-extension.pem 2048
#   # 2. Extract public key in base64 DER format
#   openssl rsa -in .keys/chrome-extension.pem -pubout -outform DER | openssl base64 -A
#
# Example shape:
#
#   WXT_CHROME_EXTENSION_KEY="MIIBIjANBgkqhkiG9w0BAQEFA..."
#  copy to other $ cp ./apps/browser-extension/.env.development ./apps/native-host/
WXT_CHROME_EXTENSION_KEY=""

# Native messaging host name used by browser.runtime.connectNative.
# Defaults to pi_native_bridge when omitted.
WXT_NATIVE_HOST_NAME=pi_native_bridge

# -----------------------------------------------------------------------------
# Native messaging host setup
# -----------------------------------------------------------------------------
# These are read by apps/native-host/setup-native-host.mjs via process.env.
# They are NOT exposed to extension code because they do not use WXT_ or VITE_.
# If using this file for native-host setup, export/source these variables before running the setup command.

# Browser target for native host installation. Example values: chrome, chromium, brave, edge, firefox.
NATIVE_HOST_BROWSER=""

# Optional override for the extension ID allowed to connect to the native host.
# Useful after publishing to Chrome Web Store or if manifest.key is not available to the setup script.
CHROME_EXTENSION_ID=""
