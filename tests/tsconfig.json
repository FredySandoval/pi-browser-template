{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun-types", "node", "chrome"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "**/*.ts",
    "../apps/**/*.ts",
    "../apps/**/*.cts",
    "../packages/**/*.ts",
    "../types.d.ts"
  ],
  "exclude": ["../dist"]
}
